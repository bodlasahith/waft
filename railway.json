{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build --workspace=packages/shared --workspace=packages/api"
  },
  "deploy": {
    "startCommand": "npm run start --workspace=packages/api",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
