# Public client config (the anon key is safe to ship — access is enforced
# server-side). Copy to .env and fill in from your Supabase project.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Use your machine's LAN IP (not localhost) so a phone on the same
# network can reach the local API.
EXPO_PUBLIC_API_URL=http://192.168.1.xxx:3001
