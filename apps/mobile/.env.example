# Public client config (the anon key is safe to ship — access is enforced
# server-side). Copy to .env and fill in from your Supabase project.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Local dev on the iOS simulator can use http://localhost:3001; a physical
# phone needs your machine's LAN IP, or just point at the deployed API.
EXPO_PUBLIC_API_URL=https://waft-production.up.railway.app
# Origin encoded into card/event QR codes (and accepted by the scanner) —
# the deployed web app, so any camera app can open scanned cards.
EXPO_PUBLIC_CARD_ORIGIN=https://waft-web.vercel.app
